# OS
.DS_Store
.Rhistory

# Python
__pycache__/
*.pyc
.venv/
.env

# Large model files and local-only assets
/local-models/
*.pt
*.pte
*.bin
*.gguf
*.onnx

# Un-ignore Android UI subdirectory that happens to be named "models"
!android/app/src/main/java/com/eai/edgellmbench/ui/models/

# Results — raw JSONL runs ARE tracked (canonical data); only exclude smoke/test runs
results/smoke-*.jsonl
results/test-*.jsonl

# Generated figures and analysis outputs (regenerated by analysis/generate_figures.py)
figures/*.png
figures/*.csv

# LaTeX build artifacts
report/*.aux
report/*.log
report/*.out
report/*.toc
report/*.fls
report/*.fdb_latexmk

# Android / Gradle
android/.idea/
android/.gradle/
android/build/
android/**/build/
*.apk
*.aab
local.properties

# Build logs (keep .dat calibration data)
*.log
vendor/

# Archive directory (kept locally, not tracked)
archive/

# Claude Code worktrees (local only, not for CI)
.claude/worktrees/
