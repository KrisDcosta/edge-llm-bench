\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Time-to-first-token (seconds) as a function of context length for each variant. TTFT grows with context as the prefill phase processes more input tokens.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:ttft_context}{{2}{4}{Time-to-first-token (seconds) as a function of context length for each variant. TTFT grows with context as the prefill phase processes more input tokens}{figure.2}{}}
