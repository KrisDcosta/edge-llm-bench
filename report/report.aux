\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Decode throughput (tokens/s) for each quantization variant at 256-token context, with standard deviation error bars over 5 trials and 3 prompt types. The non-monotonic ordering (Q2\_K $>$ Q4\_K\_M $\approx $ Q8\_0 $>$ Q3\_K\_M $>$ Q6\_K) is the primary empirical finding of this work.}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:decode_tps}{{1}{3}{Decode throughput (tokens/s) for each quantization variant at 256-token context, with standard deviation error bars over 5 trials and 3 prompt types. The non-monotonic ordering (Q2\_K $>$ Q4\_K\_M $\approx $ Q8\_0 $>$ Q3\_K\_M $>$ Q6\_K) is the primary empirical finding of this work}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {IV-B}}RQ2: Context Length Scaling}{3}{subsection.4.2}\protected@file@percent }
\newlabel{sec:rq2}{{\mbox  {IV-B}}{3}{RQ2: Context Length Scaling}{subsection.4.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {I}{\ignorespaces Benchmark Results for Llama 3.2 3B Instruct GGUF Variants on Google Pixel 6a (Tensor G2). Decode TPS and prefill TPS are aggregated at 256-token context. TTFT and E2E latency are means across all contexts and trials. PPL values are reference estimates from GGML community benchmarks.}}{4}{table.1}\protected@file@percent }
\newlabel{tab:main_results}{{I}{4}{Benchmark Results for Llama 3.2 3B Instruct GGUF Variants on Google Pixel 6a (Tensor G2). Decode TPS and prefill TPS are aggregated at 256-token context. TTFT and E2E latency are means across all contexts and trials. PPL values are reference estimates from GGML community benchmarks}{table.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Time-to-first-token (seconds) as a function of context length for each variant. TTFT grows with context as the prefill phase processes more tokens, with approximately linear scaling for most variants.}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:ttft_context}{{2}{4}{Time-to-first-token (seconds) as a function of context length for each variant. TTFT grows with context as the prefill phase processes more tokens, with approximately linear scaling for most variants}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Prefill throughput (tokens/s) as a function of context length. Prefill throughput is largely stable across context lengths for most variants, indicating that the prefill phase is also dominated by memory-bandwidth considerations at the sizes tested.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:prefill_tps}{{3}{4}{Prefill throughput (tokens/s) as a function of context length. Prefill throughput is largely stable across context lengths for most variants, indicating that the prefill phase is also dominated by memory-bandwidth considerations at the sizes tested}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Fraction of total inference time consumed by prefill vs. decode phases for each quantization variant. Decode time dominates for all variants, but the prefill fraction increases for smaller quantizations due to higher relative decode speed.}}{4}{figure.4}\protected@file@percent }
\newlabel{fig:prefill_decode_fraction}{{4}{4}{Fraction of total inference time consumed by prefill vs. decode phases for each quantization variant. Decode time dominates for all variants, but the prefill fraction increases for smaller quantizations due to higher relative decode speed}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {\mbox  {IV-C}}RQ3: Prefill vs. Decode Time Fraction}{4}{subsection.4.3}\protected@file@percent }
\newlabel{sec:rq3}{{\mbox  {IV-C}}{4}{RQ3: Prefill vs. Decode Time Fraction}{subsection.4.3}{}}
