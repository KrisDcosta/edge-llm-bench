\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Efficiency--accuracy Pareto frontier: on-device factual accuracy (\%) vs.\ decode throughput (tokens/s) for all five non-F16 variants. Dotted iso-efficiency contours show equal TPS$\times $accuracy product (E). Q8\_0 (100\%, 4.95~tok/s) and Q2\_K (93.3\%, 5.66~tok/s) are Pareto-optimal; the grey shaded region is dominated. Q6\_K (86.7\%, 3.98~tok/s) is strictly dominated on \emph  {both} axes.}}{5}{figure.5}\protected@file@percent }
\newlabel{fig:pareto}{{5}{5}{Efficiency--accuracy Pareto frontier: on-device factual accuracy (\%) vs.\ decode throughput (tokens/s) for all five non-F16 variants. Dotted iso-efficiency contours show equal TPS$\times $accuracy product (E). Q8\_0 (100\%, 4.95~tok/s) and Q2\_K (93.3\%, 5.66~tok/s) are Pareto-optimal; the grey shaded region is dominated. Q6\_K (86.7\%, 3.98~tok/s) is strictly dominated on \emph {both} axes}{figure.5}{}}
